<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  macOS LaunchAgent for claude-code-server
  =========================================

  Install:
    ./scripts/install-launchd.sh

  Uninstall:
    ./scripts/uninstall-launchd.sh

  Manual install:
    cp scripts/com.codyshort.claude-code-server.plist ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/com.codyshort.claude-code-server.plist

  Manual uninstall:
    launchctl unload ~/Library/LaunchAgents/com.codyshort.claude-code-server.plist
    rm ~/Library/LaunchAgents/com.codyshort.claude-code-server.plist

  View logs:
    tail -f ~/Library/Logs/claude-code-server.log

  Check status:
    launchctl list | grep claude-code-server
    curl -s http://127.0.0.1:18795/backend-api/claude-code/tools
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.codyshort.claude-code-server</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/node</string>
        <string>/Users/codyshort/openclaw-claude-code-skill/dist/server.js</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/codyshort/openclaw-claude-code-skill</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/Users/codyshort/.local/bin:/Users/codyshort/.npm-global/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key>
        <string>/Users/codyshort</string>
        <key>NODE_ENV</key>
        <string>production</string>
        <key>CLAUDE_CODE_PORT</key>
        <string>18795</string>
        <key>CLAUDE_CODE_HOST</key>
        <string>127.0.0.1</string>
    </dict>

    <!-- Auto-start on login -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Restart on crash -->
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <!-- Throttle restarts: wait 10 seconds between restart attempts -->
    <key>ThrottleInterval</key>
    <integer>10</integer>

    <!-- Logging -->
    <key>StandardOutPath</key>
    <string>/Users/codyshort/Library/Logs/claude-code-server.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/codyshort/Library/Logs/claude-code-server.log</string>

    <!-- Soft resource limits -->
    <key>SoftResourceLimits</key>
    <dict>
        <key>NumberOfFiles</key>
        <integer>4096</integer>
    </dict>
</dict>
</plist>
